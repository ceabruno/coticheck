# =========================
# BACKEND (Python / FastAPI)
# =========================
# Entornos virtuales (¡Muy importante no subir esto!)
.venv/
venv/
env/
ENV/

# Archivos compilados y caché de Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Bases de datos locales
*.sqlite3
*.db

# =========================
# FRONTEND (Node / React / Vite)
# =========================
# Dependencias de Node (¡Pesan muchísimo!)
node_modules/

# Carpetas de compilación o empaquetado (lo que genera Vite al final)
dist/
dist-ssr/
build/

# Logs de errores de NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# VARIABLES DE ENTORNO (Seguridad)
# =========================
# Aquí irían tus claves de Laudus o Texora en el futuro
.env
.env.local
.env.*.local

# =========================
# SISTEMA OPERATIVO Y EDITORES
# =========================
# Archivos de Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Archivos de Mac (por si otro desarrollador usa Apple)
.DS_Store

# Configuraciones locales de editores de código (VS Code, IntelliJ, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
